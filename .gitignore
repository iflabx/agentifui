.env.*
.env
!.env.example
!.env.prod.example
!.env.test.example

# docs
docs/security

# pm2
pm2-logs/

# local tooling artifacts
.dev-env.local
.playwright-cli/
output/
local-scripts/
local_scripts/
local-docs/
local_docs/

.serena
