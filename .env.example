# ===========================================
# PostgreSQL / Redis / S3 Configuration
# ===========================================

DATABASE_URL=postgresql://agentif:agentif@127.0.0.1:5432/agentifui
# Optional fallback key used by some scripts.
# PGURL=postgresql://agentif:agentif@127.0.0.1:5432/agentifui

# Optional RLS strict mode toggle shared by Next + Fastify PG contexts.
# 0 (default): compatibility mode
# 1: strict mode (no implicit actor bypass)
# APP_RLS_STRICT_MODE=0

REDIS_URL=redis://127.0.0.1:6379/0

S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=agentifui
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Optional: defaults to us-east-1
# S3_REGION=us-east-1
# Optional: public base URL for object access
# S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/agentifui
# Optional: set to 0 for private bucket reads, 1 for public object reads
# S3_PUBLIC_READ_ENABLED=1
# Optional: comma-separated trusted hosts for avatar URLs (used by client-side sanitization)
# TRUSTED_AVATAR_HOSTS=127.0.0.1:9000,cdn.example.com

# ===========================================
# API Encryption Key
# ===========================================

API_ENCRYPTION_KEY=your-32-byte-hex-string
# To generate: openssl rand -hex 32

# ===========================================
# Application Settings
# ===========================================

NEXT_PUBLIC_APP_URL=https://your-domain.com

# ===========================================
# Fastify API Sidecar (optional)
# ===========================================

# Enable Next.js rewrites for selected /api prefixes to Fastify.
# FASTIFY_PROXY_ENABLED=0
# FASTIFY_PROXY_BASE_URL=http://127.0.0.1:3010
# FASTIFY_PROXY_PREFIXES=/api/internal/data,/api/internal/apps,/api/internal/profile,/api/internal/dify-config,/api/internal/auth/local-password,/api/internal/fastify-health,/api/admin,/api/translations

# Fastify runtime settings
# FASTIFY_API_HOST=0.0.0.0
# FASTIFY_API_PORT=3010
# FASTIFY_LOG_LEVEL=info

# Upstream Next.js endpoint used by Fastify fallback proxy for not-yet-migrated routes.
# NEXT_UPSTREAM_BASE_URL=http://127.0.0.1:3000

# Optional: temporary rollback switch for Fastify auth identity resolution.
# Keep disabled in normal operation; when enabled, Fastify may fallback to
# Next /api/internal/auth/profile-status only if local resolver errors.
# FASTIFY_UPSTREAM_PROFILE_STATUS_FALLBACK_ENABLED=0

# ===========================================
# Authentication & SSO
# ===========================================

NEXT_PUBLIC_SSO_ONLY_MODE=false

# Default email domain for SSO users when not configured per provider
# DEFAULT_SSO_EMAIL_DOMAIN=sso.local

# ===========================================
# Better Auth (M2 parallel rollout)
# ===========================================

# Keep false until M2 cutover.
BETTER_AUTH_ENABLED=false

# Backend selector: better-auth
AUTH_BACKEND=better-auth

# Public app URL used by better-auth callback generation.
# BETTER_AUTH_URL=https://your-domain.com

# Required in production when BETTER_AUTH_ENABLED=true
# BETTER_AUTH_SECRET=your-long-random-secret

# Optional: generic OAuth providers for local/mock OAuth E2E verification.
# Example:
# BETTER_AUTH_GENERIC_OAUTH_PROVIDERS_JSON=[
#   {
#     "providerId":"github",
#     "authorizationUrl":"http://127.0.0.1:3901/oauth/authorize",
#     "tokenUrl":"http://127.0.0.1:3901/oauth/token",
#     "userInfoUrl":"http://127.0.0.1:3901/oauth/userinfo",
#     "clientId":"mock-client",
#     "clientSecret":"mock-secret",
#     "scopes":["read:user","user:email"]
#   }
# ]

# Optional: static SSO providers for better-auth plugin.
# Supports native OIDC and CAS->OIDC bridge metadata.
# Example:
# BETTER_AUTH_SSO_PROVIDERS_JSON=[
#   {
#     "providerId":"corp-oidc",
#     "domain":"example.com",
#     "issuer":"https://idp.example.com",
#     "clientId":"your-client-id",
#     "clientSecret":"your-client-secret",
#     "mode":"native"
#   },
#   {
#     "providerId":"campus-cas-bridge",
#     "domain":"campus.edu",
#     "issuer":"https://oidc-bridge.example.com/campus",
#     "clientId":"bridge-client-id",
#     "clientSecret":"bridge-client-secret",
#     "mode":"cas-bridge",
#     "casIssuer":"https://cas.campus.edu/cas"
#   }
# ]

# Optional: enforce strict SSO parsing (e.g. cas-bridge requires casIssuer).
# Defaults to true in production/CI, false in local dev.
# BETTER_AUTH_SSO_STRICT=false

# Optional: auth session tuning.
# BETTER_AUTH_SESSION_EXPIRES_IN_SECONDS=604800
# BETTER_AUTH_SESSION_UPDATE_AGE_SECONDS=86400
# BETTER_AUTH_STORE_SESSION_IN_DB=true
# BETTER_AUTH_PRESERVE_SESSION_IN_DB=false

# Identity synchronization mode:
# - false (recommended): request-time auth resolution is read-only;
#   identity/profile side effects run after successful login responses.
# - true: keep legacy inline sync behavior during session resolution.
# AUTH_IDENTITY_SYNC_INLINE=false

# Optional: when read-only auth resolve fails because non-UUID user mapping
# has not been materialized yet, run one side-effect sync as compensation.
# AUTH_IDENTITY_RECOVER_MISSING_MAPPING=true

# Optional: post-login side-effect sync retry policy.
# AUTH_IDENTITY_SYNC_RETRY_ATTEMPTS=3
# AUTH_IDENTITY_SYNC_RETRY_DELAY_MS=250

# Password reset sender mode:
# - dev-log: print reset link/token to server logs
# - smtp: send email through SMTP settings below
# AUTH_RESET_PASSWORD_MODE=dev-log
# AUTH_RESET_PASSWORD_SUBJECT=AgentifUI Password Reset
# AUTH_RESET_PASSWORD_EMAIL_FROM=AgentifUI <no-reply@example.com>

# SMTP settings (required when AUTH_RESET_PASSWORD_MODE=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=mailer-account
# SMTP_PASSWORD=mailer-password
# SMTP_FROM=AgentifUI <no-reply@example.com>

# Phone OTP settings
# AUTH_PHONE_OTP_ENABLED=true
# AUTH_PHONE_OTP_MODE=dev-log
# AUTH_PHONE_OTP_LENGTH=6
# AUTH_PHONE_OTP_EXPIRES_IN=300
# AUTH_PHONE_OTP_ALLOWED_ATTEMPTS=3
# AUTH_PHONE_SIGNUP_ON_VERIFICATION=true
# AUTH_PHONE_TEMP_EMAIL_DOMAIN=phone.local

# Optional HTTP OTP provider (when AUTH_PHONE_OTP_MODE=http)
# AUTH_PHONE_OTP_API_URL=https://sms-provider.example.com/send
# AUTH_PHONE_OTP_API_TOKEN=your-api-token
# AUTH_PHONE_OTP_API_TOKEN_HEADER=authorization
# AUTH_PHONE_OTP_HTTP_TIMEOUT_MS=8000

# ===========================================
# CORS Settings
# ===========================================

CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional for development only.
# If not set, only NEXT_PUBLIC_APP_URL will be allowed.
# DEV_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
